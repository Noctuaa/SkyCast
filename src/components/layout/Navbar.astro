---
import Toolbar from './Toolbar.vue';
const prefs = Astro.cookies.get('skycast_prefs')?.json();
const initialUnit = prefs?.unit ?? 'C';
const url = new URL(Astro.request.url);
const initialLang = (url.searchParams.get('lang') ?? prefs?.lang ?? 'fr') as 'fr' | 'en';
---

<header class="toolbar fixed z-1000 flex ai-center w-full">
  <div class="container w-full flex ai-center jc-between">
    <a href="/" class="flex ai-center gap-2" aria-label="SkyCast">
      <img src="/favicon.svg" alt="SkyCast" width="32" height="32" />
      <h1 class="text-xl font-bold tracking-tight ink-1">
        Sky<span class="accent">Cast</span>
      </h1>
    </a>

    <nav class="toolbar-nav fixed flex flex-col md:flex-row ai-center jc-start gap-2 p-3" id="toolbar-nav">
      <Toolbar client:load initialUnit={initialUnit} initialLang={initialLang} />
    </nav>

    <button class="hamburger flex flex-col gap-1 p-2" id="hamburger-btn" aria-label="Menu">
      <span class="block"></span>
      <span class="block"></span>
      <span class="block"></span>
    </button>
  </div>
</header>

<script>
  import { $navOpen } from '../../stores/uiStore';
  import type { TransitionBeforeSwapEvent } from 'astro:transitions/client';

  /**
   * Restores the open drawer state on the incoming DOM before the page swap.
   * Called on astro:before-swap so classes are applied without any visible transition.
   * $navOpen is set to true by Toolbar before any navigate() call.
   */
  const renoveNavState = (event: TransitionBeforeSwapEvent) => {
    if ($navOpen.get()) {
      const nav = event.newDocument.getElementById('toolbar-nav');
      const hamburger = event.newDocument.getElementById('hamburger-btn');
      nav?.classList.add('open');
      hamburger?.classList.add('active');
      $navOpen.set(false);
    }
  };

  /** Binds the hamburger click to toggle the mobile drawer. Re-run on each page load. */
  const setupHamburger = () => {
    const hamburger = document.getElementById('hamburger-btn');
    const nav = document.getElementById('toolbar-nav');

    hamburger?.addEventListener('click', () => {
      nav?.classList.toggle('open');
      hamburger.classList.toggle('active');
    });
  };

  document.addEventListener('astro:before-swap', renoveNavState);
  document.addEventListener('astro:page-load', setupHamburger);
</script>
