<script>
  import { $searchOpen } from '../stores/forecastStore';
  import { $unit, $lang, $theme, saveConfig } from '../stores/configStore';

  function setupToolbar() {
    const searchBtn = document.getElementById('search-btn');
    const unitToggle = document.getElementById('unit-toggle');
    const langToggle = document.getElementById('lang-toggle');
    const themeToggle = document.getElementById('theme-toggle');

    if (unitToggle) unitToggle.textContent = `°${$unit.get()}`;
    const urlLang = new URL(window.location.href).searchParams.get('lang');
    const currentLang = urlLang === 'en' ? 'en' : 'fr';
    if (langToggle)
      langToggle.textContent = currentLang === 'en' ? '\u{1F1EB}\u{1F1F7}' : '\u{1F1EC}\u{1F1E7}';

    searchBtn?.addEventListener('click', () => {
      const hasCity = new URL(window.location.href).searchParams.get('city') !== null;
      if ($searchOpen.get() && !hasCity) return;
      $searchOpen.set(!$searchOpen.get());
    });

    unitToggle?.addEventListener('click', () => {
      const next = $unit.get() === 'C' ? 'F' : 'C';
      $unit.set(next);
      if (unitToggle) unitToggle.textContent = `°${next}`;
      saveConfig();
      window.location.reload();
    });

    langToggle?.addEventListener('click', () => {
      const next = currentLang === 'fr' ? 'en' : 'fr';
      $lang.set(next);
      saveConfig();
      const cityId = new URL(window.location.href).searchParams.get('city');
      if (cityId) window.location.href = `/?lang=${next}&city=${cityId}`;
    });

    themeToggle?.addEventListener('click', () => {
      const next = $theme.get() === 'light' ? 'dark' : 'light';
      const switchTheme = () => {
        $theme.set(next);
        document.documentElement.setAttribute('data-theme', next);
        saveConfig();
      };
      if (!document.startViewTransition) {
        switchTheme();
        return;
      }
      document.startViewTransition(switchTheme);
    });
  }

  document.addEventListener('astro:page-load', setupToolbar);
</script>

<style>
  .icon-moon {
    display: none;
  }

  :global([data-theme='dark']) .icon-sun {
    transform: rotate(180deg);
    opacity: 0;
    display: none;
    transition: ease 0.6s;
  }
  :global([data-theme='dark']) .icon-moon {
    display: inline;
  }
</style>
