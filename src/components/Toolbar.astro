</button>
<button class="btn-tools unit-toggle" id="unit-toggle">°C</button>
<button class="btn-tools lang-toggle" id="lang-toggle"></button>
<button class="btn-tools" id="theme-toggle" aria-label="Toggle theme">
  <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512">
