<button class="toolbar-btn flex-center" id="search-btn" aria-label="Rechercher">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
    <path
      d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 
  0 322.9 0 208S93.1 0 208 0S416 93.1 416 208zM208 352a144 144 0 1 0 0-288 144 144 0 1 0 0 288z"
    >
    </path>
  </svg>
</button>
<button class="toolbar-btn unit-toggle" id="unit-toggle">°C</button>
<button class="toolbar-btn lang-toggle" id="lang-toggle"></button>

<script>
  import { $forecast, $searchOpen } from '../stores/forecastStore';
  import { $unit, $lang, saveConfig } from '../stores/configStore';
  import { fetchForecast } from '../stores/actions';

  // Buttons
  const searchBtn = document.getElementById('search-btn');
  const unitToggle = document.getElementById('unit-toggle');
  const langToggle = document.getElementById('lang-toggle');

  // Init button labels from saved preferences
  if (unitToggle) unitToggle.textContent = `°${$unit.get()}`;
  if (langToggle)
    langToggle.textContent = document.documentElement.lang === 'en' ? '\u{1F1EC}\u{1F1E7}' : '\u{1F1EB}\u{1F1F7}';

  // Search — prevent closing if no city is selected
  searchBtn?.addEventListener('click', () => {
    const canClose = $forecast.get() !== null;
    if ($searchOpen.get() && !canClose) return;
    $searchOpen.set(!$searchOpen.get());
  });

  // Unit toggle — converts and persists preference
  unitToggle?.addEventListener('click', () => {
    const next = $unit.get() === 'C' ? 'F' : 'C';
    $unit.set(next);
    if (unitToggle) unitToggle.textContent = `°${next}`;
    saveConfig();
  });

  // Lang toggle — updates html[lang] attribute and persists preference
  langToggle?.addEventListener('click', async () => {
    const next = $lang.get() === 'fr' ? 'en' : 'fr';
    $lang.set(next);
    document.documentElement.lang = next;
    if (langToggle) langToggle.textContent = next === 'fr' ? '\u{1F1EB}\u{1F1F7}' : '\u{1F1EC}\u{1F1E7}';
    saveConfig();
    if ($forecast.get() !== null) await fetchForecast();
  });
</script>
