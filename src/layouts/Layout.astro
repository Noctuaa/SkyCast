---
// @ts-expect-error — no types for fontsource CSS packages
import '@fontsource-variable/manrope';
import '../assets/styles/main.css';
import Head from '../components/layout/Head.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  lang?: 'fr' | 'en';
}

const { title, description, lang: langProp } = Astro.props;
const prefs = Astro.cookies.get('skycast_prefs')?.json();
const url = new URL(Astro.request.url);
const lang = langProp ?? (url.searchParams.get('lang') ?? prefs?.lang ?? 'fr') as 'fr' | 'en';
---

<!doctype html>
<html lang={lang}>
  <head>
    <Head title={title} description={description} />
    <ClientRouter />
    <script is:inline>
      const applyConfig = () => {
        const config = JSON.parse(localStorage.getItem('skycast_config') ?? '{}');
        const theme = config.theme ?? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.lang = config.lang ?? 'fr';
      };
      applyConfig();
      document.addEventListener('astro:after-swap', applyConfig);
    </script>
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer lang={lang} />
  </body>
</html>
