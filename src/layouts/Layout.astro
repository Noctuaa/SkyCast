---
// @ts-expect-error — no types for fontsource CSS packages
import '@fontsource-variable/manrope';
import '../assets/styles/main.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>SkyCast</title>
    <ClientRouter />
    <script is:inline>
      const applyConfig = () => {
        const config = JSON.parse(localStorage.getItem('skycast_config') ?? '{}');
        const theme = config.theme ?? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.lang = config.lang ?? 'fr';
      };
      applyConfig();
      document.addEventListener('astro:after-swap', applyConfig);
    </script>
  </head>
  <body>
    <!--<img src="/background.svg" class="bg-svg" alt="" aria-hidden="true" />-->
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>
    <div class="bg-blob blob-3"></div>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>
