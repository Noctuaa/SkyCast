---
import Layout from '../layouts/Layout.astro';

import WeatherMain from '../components/cards/WeatherMain.vue';
import MapCard from '../components/cards/MapCard.vue';
import WindCard from '../components/cards/WindCard.vue';
import SunCard from '../components/cards/SunCard.vue';
import AirCard from '../components/cards/AirCard.vue';
import ForecastCard from '../components/cards/ForecastCard.vue';
import ChartCard from '../components/cards/ChartCard.vue';

import { translations } from '../i18n/translations';

import { isValidCoords } from '../utils/coords';

import type { OMResponse, OMAirQualityResponse } from '../types/weather';

import '../assets/styles/pages/index.css';

// ── 1. Coordinates ──
const url = Astro.url;
const latParam = url.searchParams.get('lat');
const lonParam = url.searchParams.get('lon');
const urlCoordsValid = latParam !== null && lonParam !== null && isValidCoords(latParam, lonParam);

const locationCookieRaw = Astro.cookies.get('skycast_location')?.value;
const locationCookieParsed = locationCookieRaw ? JSON.parse(decodeURIComponent(locationCookieRaw)) : null;

// Fallback: location cookie → Paris by default
const lat = urlCoordsValid ? latParam! : (locationCookieParsed?.lat?.toString() ?? '48.8566');
const lon = urlCoordsValid ? lonParam! : (locationCookieParsed?.lon?.toString() ?? '2.3522');

// ── 2. Language ──
const prefsCookie = Astro.cookies.get('skycast_prefs')?.value;
const prefs = prefsCookie ? JSON.parse(decodeURIComponent(prefsCookie)) : {};
const langParam = url.searchParams.get('lang');
const acceptLang = Astro.request.headers.get('accept-language') ?? '';
const browserLang = acceptLang.toLowerCase().startsWith('en') ? 'en' : 'fr';

let lang: 'fr' | 'en';
if (langParam !== null && ['fr', 'en'].includes(langParam)) {
  lang = langParam as 'fr' | 'en';
} else if (langParam === null) {
  lang = (prefs.lang ?? browserLang) as 'fr' | 'en';
} else {
  lang = browserLang;
}

// ── 3. Redirect if URL has no valid coords to keep URL in sync ──
if (!urlCoordsValid) {
  return Astro.redirect(`/?lang=${lang}&lat=${lat}&lon=${lon}`);
}

const t = translations[lang];
const unit = (['C', 'F'].includes(prefs.unit) ? prefs.unit : 'C') as 'C' | 'F';

// ── 4. Fetch weather data ──
let forecast: OMResponse | null = null;
let airQuality: OMAirQualityResponse | null = null;
let forecastError = false;

const [forecastRes, airRes] = await Promise.all([
  fetch(`${url.origin}/api/forecast?lat=${lat}&lon=${lon}`),
  fetch(`${url.origin}/api/air-quality?lat=${lat}&lon=${lon}`),
]);

if (forecastRes.ok) forecast = await forecastRes.json();
else forecastError = true;
if (airRes.ok) airQuality = await airRes.json();

// ── 5. Location name ──

//prettier-ignore
const cookieMatchesCoords = locationCookieParsed && Math.abs(locationCookieParsed.lat - Number(lat)) < 0.01 && Math.abs(locationCookieParsed.lon - Number(lon)) < 0.01;

let locationData;

if (cookieMatchesCoords) {
  locationData = locationCookieParsed;
} else {
  const reverseRes = await fetch(`${url.origin}/api/reverse-geocoding?lat=${lat}&lon=${lon}&lang=${lang}`);
  if (reverseRes.ok) {
    const reversed = await reverseRes.json();
    locationData = { ...reversed, lat: Number(lat), lon: Number(lon) };
  } else {
    locationData = { name: 'Paris', country: 'France', state: '', lat: Number(lat), lon: Number(lon) };
  }
  Astro.cookies.set('skycast_location', encodeURIComponent(JSON.stringify(locationData)), {
    path: '/',
    maxAge: 31536000,
  });
}

// ── 6. Sunrise / Sunset ──
// Converts a local Open-Meteo ISO string to a UTC Unix timestamp
const isoToUnix = (iso: string, utcOffset: number) => Math.floor(new Date(iso + 'Z').getTime() / 1000) - utcOffset;

const sunriseUnix = forecast ? isoToUnix(forecast.daily.sunrise[0], forecast.utc_offset_seconds) : 0;
const sunsetUnix = forecast ? isoToUnix(forecast.daily.sunset[0], forecast.utc_offset_seconds) : 0;
---

<script>
  import { $searchOpen } from '../stores/uiStore';
  if (!new URL(window.location.href).searchParams.get('lat')) {
    $searchOpen.set(true);
  }
</script>

<Layout lang={lang}>
  <main class="container">
    {
      forecastError && (
        <div class="box flex ai-center jc-between w-full">
          <div class="flex ai-start gap-3">
            <span class="text-xl" aria-hidden="true">
              ⚠
            </span>
            <div class="flex flex-col gap-2">
              <p class="font-semibold text-base">{t.apiErrorTitle}</p>
              <p class="text-sm ink-2">{t.apiErrorDesc}</p>
            </div>
          </div>
          <button onclick="window.location.reload()" class="btn btn-glass p-3 text-xs ink-1 font-semibold">
            {t.apiErrorRetry}
          </button>
        </div>
      )
    }
    <div class:list={['bento', { hidden: forecastError }]}>
      <section class="cell-main glass">
        {
          forecast && (
            <WeatherMain
              client:load
              current={forecast.current}
              uvIndex={forecast.daily.uv_index_max[0]}
              country={locationData.country}
              locationName={locationData.name}
              locationState={locationData.state ?? ''}
              initialLang={lang}
              initialUnit={unit}
            />
          )
        }
      </section>

      <section class="cell-map glass">
        {
          forecast && (
            <MapCard
              client:media="(min-width: 768px)"
              lat={forecast.latitude}
              lon={forecast.longitude}
              name={locationData.name}
            />
          )
        }
      </section>

      <section class="cell-wind glass">
        <div class="panel-head"><h3 class="panel-title">{t.wind}</h3></div>
        {
          forecast && (
            <WindCard
              client:load
              windSpeed={forecast.current.wind_speed_10m}
              windDeg={forecast.current.wind_direction_10m}
              windGust={forecast.current.wind_gusts_10m}
              cloudCover={forecast.current.cloud_cover}
              visibility={forecast.current.visibility}
              initialLang={lang as 'fr' | 'en'}
            />
          )
        }
      </section>

      <section class="cell-sun glass">
        <div class="panel-head"><h3 class="panel-title">{t.sunriseSunset}</h3></div>
        {
          forecast && (
            <SunCard
              client:load
              sunrise={sunriseUnix}
              sunset={sunsetUnix}
              timezone={forecast.utc_offset_seconds}
              initialLang={lang as 'fr' | 'en'}
            />
          )
        }
      </section>

      <section class="cell-air glass">
        <div class="panel-head">
          <h3 class="panel-title">{t.airQuality}</h3>
        </div>
        {
          airQuality && (
            <AirCard
              client:load
              airQuality={airQuality.current}
              locationName={locationData.name}
              initialLang={lang as 'fr' | 'en'}
            />
          )
        }
      </section>
      <section class="cell-forecast glass">
        <div class="panel-head">
          <h3 class="panel-title">{t.forecast}</h3>
          <span class="eyebrow">{t.forecastPrev}</span>
        </div>
        {forecast && <ForecastCard client:load daily={forecast.daily} />}
      </section>
      <section class="cell-chart glass">
        <div class="panel-head">
          <h3 class="panel-title">{t.chartTitle}</h3>
          <span class="eyebrow">{t.chartInterval}</span>
        </div>
        {forecast && <ChartCard client:load hourly={forecast.hourly} />}
      </section>
    </div>
  </main>
</Layout>
