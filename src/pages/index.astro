---
import Layout from '../layouts/Layout.astro';
import SearchModal from '../components/SearchModal.vue';
import WeatherMain from '../components/WeatherMain.vue';
import WeatherCard from '../components/WeatherCard.astro';
import ForecastCard from '../components/ForecastCard.vue';
import ChartCard from '../components/ChartCard.vue';
import MapCard from '../components/MapCard.vue';
import type { ForecastResponse } from '../types/weather';
import WindCard from '../components/WindCard.vue';
import SunCard from '../components/SunCard.vue';
import AirCard from '../components/AirCard.vue';
import { translations } from '../i18n/translations';

const url = Astro.url;
const cityParam = url.searchParams.get('city') ?? '';
const hasValidId = cityParam.length > 0 && !isNaN(Number(cityParam));

const prefsCookie = Astro.cookies.get('skycast_prefs')?.value;
const prefs = prefsCookie ? JSON.parse(decodeURIComponent(prefsCookie)) : {};
const langParam = url.searchParams.get('lang');
const acceptLang = Astro.request.headers.get('accept-language') ?? '';
const browserLang = acceptLang.toLowerCase().startsWith('en') ? 'en' : 'fr';
const lang = (
  langParam !== null && ['fr', 'en'].includes(langParam)
    ? langParam
    : langParam === null
      ? (prefs.lang ?? browserLang)
      : browserLang
) as 'fr' | 'en';
const t = translations[lang];
const unit = (prefs.unit ?? 'C') as 'C' | 'F';

let forecast: ForecastResponse | null = null;

if (hasValidId) {
  const apiKey = import.meta.env.OPENWEATHER_API_KEY;
  const res = await fetch(
    `https://api.openweathermap.org/data/2.5/forecast?id=${cityParam}&appid=${apiKey}&units=metric&lang=${lang}&cnt=40`,
  );
  if (res.ok) forecast = await res.json();
}

const locationCookie = Astro.cookies.get('skycast_location')?.value;
const locationData = locationCookie
  ? JSON.parse(decodeURIComponent(locationCookie))
  : { name: forecast?.city.name ?? '', country: forecast?.city.country ?? '', state: '' };
---

<script>
  import { $searchOpen } from '../stores/forecastStore';
  if (!new URL(window.location.href).searchParams.get('city')) {
    $searchOpen.set(true);
  }
</script>

<Layout>
  <main class="container">
    <div class="bento">
      {
        forecast && (
          <WeatherMain
            client:load
            forecast={forecast}
            initialLang={lang}
            initialUnit={unit}
            locationName={locationData.name}
            locationState={locationData.state ?? ''}
          />
        )
      }

      <section class="cell-map glass">
        {
          forecast && (
            <MapCard client:load lat={forecast.city.coord.lat} lon={forecast.city.coord.lon} name={locationData.name} />
          )
        }
      </section>

      <section class="cell-wind glass">
        <div class="panel-head">
          <h3 class="panel-title">{t.wind}</h3>
        </div>

        {
          forecast && (
            <WindCard
              client:load
              wind={forecast.list[0].wind}
              clouds={forecast.list[0].clouds}
              visibility={forecast.list[0].visibility}
              initialLang={lang as 'fr' | 'en'}
            />
          )
        }
      </section>

      <section class="cell-sun glass">
        <div class="panel-head">
          <h3 class="panel-title">{t.sunriseSunset}</h3>
        </div>
        {
          forecast && (
            <SunCard
              client:load
              sunrise={forecast.city.sunrise}
              sunset={forecast.city.sunset}
              timezone={forecast.city.timezone}
              initialLang={lang as 'fr' | 'en'}
            />
          )
        }
      </section>
      <section class="cell-air glass">
        {forecast && <AirCard client:load forecast={forecast} initialLang={lang as 'fr' | 'en'} />}
      </section>
      <section class="cell-forecast glass"></section>
      <section class="cell-chart glass"></section>
    </div>
    <SearchModal client:only="vue" />
    <!-- <div class="weather-grid grid">
      {
        forecast && (
          <WeatherCard
            forecast={forecast}
            locationName={locationData.name}
            locationCountry={locationData.country}
            unit={unit}
            lang={lang as 'fr' | 'en'}
          />
        )
      }

      {forecast && <ForecastCard forecast={forecast} client:load />}
      {
        forecast && (
          <div class="right-col">
            <div class="map-card">
              <MapCard
                lat={forecast.city.coord.lat}
                lon={forecast.city.coord.lon}
                name={locationData.name}
                client:load
              />
            </div>
            <div class="chart-card">
              <ChartCard forecast={forecast} client:load />
            </div>
          </div>
        )
      }
    </div>-->
  </main>
</Layout>

<style>
  .cell-wind,
  .cell-sun,
  .cell-air,
  .cell-forecast,
  .cell-chart {
    grid-column: span 12;
    grid-row: auto;
  }

  .cell-map {
    grid-column: span 12;
    grid-row: auto;
    padding: 0;
    min-height: 340px;
  }

  .cell-wind,
  .cell-sun,
  .cell-air,
  .cell-forecast,
  .cell-chart {
    min-height: 200px;
    padding: 16px;
  }

  @media (min-width: 768px) {
    .cell-map {
      grid-column: span 8;
      grid-row: span 2;
      min-height: unset;
    }

    .cell-wind {
      grid-column: span 4;
      min-height: 230px;
      padding: 22px;
    }

    .cell-sun {
      grid-column: span 4;
      min-height: 230px;
      padding: 22px;
    }

    .cell-air {
      grid-column: span 4;
      min-height: 230px;
      padding: 22px;
    }

    .cell-forecast {
      grid-column: span 6;
      min-height: 230px;
      padding: 22px;
    }

    .cell-chart {
      grid-column: span 6;
      min-height: 230px;
      padding: 22px;
    }
  }
</style>
